# HIL bench device configuration (Phase 0.5)
# Sourced by tools/verify.sh (bash) and parsed by the tools/*.py scripts.
# Native USB-CDC re-enumerates on every reset, so HIL_PORT is a *default
# starting point* - boot_check.py will re-glob HIL_PORT_GLOB if it vanishes.

HIL_ENV=seeed_xiao_esp32s3
HIL_PORT=/dev/cu.usbmodem111701
HIL_PORT_GLOB=/dev/cu.usbmodem*
HIL_BAUD=115200
